        {
          "type": "Text",
          "id": "57e9cdb9-46b5-43c5-a4ac-6045de7cf4be",
          "bounds": {
            "x": 70,
            "y": 54,
            "width": 760,
            "height": 64
          },
          "text": "The Svalbard Origin Story",
          "font_size": 40,
          "color": {
            "value": "#102019"
          }
        },
        {
          "type": "Text",
          "id": "dcb0afbd-5c94-4333-b8c4-985d31f925f5",
          "bounds": {
            "x": 78,
            "y": 142,
            "width": 460,
            "height": 40
          },
          "text": "One cold day, Blorbo waddled into a mountain.",
          "font_size": 24,
          "color": {
            "value": "#102019"
          }
        },
        {
          "type": "Text",
          "id": "cdbd1f42-d40b-4ccf-aaca-6edddf0f9b54",
          "bounds": {
            "x": 78,
            "y": 198,
            "width": 466.13180515759313,
            "height": 64.378223495702
          },
          "text": "Inside, he found an abandoned GPU server nest.",
          "font_size": 26,
          "color": {
            "value": "#315C6B"
          }
        },
        {
          "type": "Text",
          "id": "8c5a7098-9d56-41d9-8fc9-bd905d1a3448",
          "bounds": {
            "x": 78,
            "y": 272,
            "width": 450,
            "height": 40
          },
          "text": "It was warm. It blinked. It made tiny beepies.",
          "font_size": 23,
          "color": {
            "value": "#102019"
          }
        },
        {
          "type": "Text",
          "id": "f11ebd60-cbb3-4bd2-99e4-a875fbeff120",
          "bounds": {
            "x": 78,
            "y": 328,
            "width": 450,
            "height": 42
          },
          "text": "Blorbo said: I lives here now.",
          "font_size": 24,
          "color": {
            "value": "#E09A2D"
          }
        },
        {
          "type": "Image",
          "id": "7d96cd2f-9364-43a7-95c8-392aed819266",
